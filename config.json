{
  "llm": {
    "provider": "openai",
    "model": "gpt-5.5",
    "max_tokens": 1000,
    "temperature": 0.3,
    "providers": {
      "lmstudio": {
        "api_endpoint": "http://localhost:1234/v1/chat/completions",
        "api_key_env": "LMSTUDIO_API_KEY",
        "available_models": [
          "gemma-4-31b-it-mlx",
          "google/gemma-4-31b",
          "qwen/qwen3.6-35b-a3b",
          "qwen3.6-35b-a3b-mlx"
        ],
        "pdf_strategy": {
          "gemma-4-31b-it-mlx": "none",
          "google/gemma-4-31b": "none",
          "qwen/qwen3.6-35b-a3b": "none",
          "qwen3.6-35b-a3b-mlx": "none"
        },
        "default_model": "google/gemma-4-31b"
      },
      "anthropic": {
        "api_endpoint": "https://api.anthropic.com/v1",
        "api_key_env": "ANTHROPIC_API_KEY",
        "available_models": [
          "claude-fable-5",
          "claude-haiku-4-5-20251001",
          "claude-opus-4-1-20250805",
          "claude-opus-4-5-20251101",
          "claude-opus-4-6",
          "claude-opus-4-7",
          "claude-opus-4-8",
          "claude-sonnet-4-5-20250929",
          "claude-sonnet-4-6"
        ],
        "pdf_strategy": {
          "claude-fable-5": "inline_base64_document",
          "claude-haiku-4-5-20251001": "inline_base64_document",
          "claude-opus-4-1-20250805": "inline_base64_document",
          "claude-opus-4-5-20251101": "inline_base64_document",
          "claude-opus-4-6": "inline_base64_document",
          "claude-opus-4-7": "inline_base64_document",
          "claude-opus-4-8": "inline_base64_document",
          "claude-sonnet-4-5-20250929": "inline_base64_document",
          "claude-sonnet-4-6": "inline_base64_document"
        },
        "default_model": "claude-sonnet-4-6"
      },
      "google": {
        "api_endpoint": "https://generativelanguage.googleapis.com",
        "api_key_env": "GOOGLE_API_KEY",
        "project_id_env": "GOOGLE_PROJECT_ID",
        "location": "us-central1",
        "available_models": [
          "gemini-2.5-flash",
          "gemini-2.5-flash-lite",
          "gemini-2.5-pro",
          "gemini-3-flash-preview",
          "gemini-3-pro-preview",
          "gemini-3.1-flash-lite",
          "gemini-3.1-flash-lite-preview",
          "gemini-3.1-pro-preview",
          "gemini-3.5-flash",
          "gemini-3.5-live-translate-preview",
          "gemini-flash-latest",
          "gemini-flash-lite-latest",
          "gemini-pro-latest"
        ],
        "pdf_strategy": {
          "gemini-2.5-flash": "genai_files_upload",
          "gemini-2.5-flash-lite": "genai_files_upload",
          "gemini-2.5-pro": "genai_files_upload",
          "gemini-3-flash-preview": "genai_files_upload",
          "gemini-3-pro-preview": "genai_files_upload",
          "gemini-3.1-flash-lite": "genai_files_upload",
          "gemini-3.1-flash-lite-preview": "genai_files_upload",
          "gemini-3.1-pro-preview": "genai_files_upload",
          "gemini-3.5-flash": "genai_files_upload",
          "gemini-3.5-live-translate-preview": "none",
          "gemini-flash-latest": "genai_files_upload",
          "gemini-flash-lite-latest": "genai_files_upload",
          "gemini-pro-latest": "genai_files_upload"
        },
        "default_model": "gemini-flash-latest"
      },
      "openai": {
        "api_endpoint": "https://api.openai.com/v1",
        "api_key_env": "OPENAI_API_KEY",
        "available_models": [
          "gpt-4-turbo",
          "gpt-4.1",
          "gpt-4.1-mini",
          "gpt-4.1-nano",
          "gpt-4o",
          "gpt-4o-mini",
          "gpt-5",
          "gpt-5-chat-latest",
          "gpt-5-mini",
          "gpt-5-nano",
          "gpt-5-pro",
          "gpt-5.1",
          "gpt-5.1-chat-latest",
          "gpt-5.2",
          "gpt-5.2-chat-latest",
          "gpt-5.2-pro",
          "gpt-5.3-chat-latest",
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.4-nano",
          "gpt-5.4-pro",
          "gpt-5.5",
          "gpt-5.5-pro",
          "o3",
          "o3-mini",
          "o3-pro",
          "o4-mini"
        ],
        "pdf_strategy": {
          "gpt-4-turbo": "files_api_responses",
          "gpt-4.1": "files_api_responses",
          "gpt-4.1-mini": "files_api_responses",
          "gpt-4.1-nano": "files_api_responses",
          "gpt-4o": "files_api_responses",
          "gpt-4o-mini": "files_api_responses",
          "gpt-5": "files_api_responses",
          "gpt-5-chat-latest": "files_api_responses",
          "gpt-5-mini": "files_api_responses",
          "gpt-5-nano": "files_api_responses",
          "gpt-5-pro": "files_api_responses",
          "gpt-5.1": "files_api_responses",
          "gpt-5.1-chat-latest": "files_api_responses",
          "gpt-5.2": "files_api_responses",
          "gpt-5.2-chat-latest": "files_api_responses",
          "gpt-5.2-pro": "files_api_responses",
          "gpt-5.3-chat-latest": "files_api_responses",
          "gpt-5.4": "files_api_responses",
          "gpt-5.4-mini": "files_api_responses",
          "gpt-5.4-nano": "files_api_responses",
          "gpt-5.4-pro": "files_api_responses",
          "gpt-5.5": "files_api_responses",
          "gpt-5.5-pro": "files_api_responses",
          "o3": "files_api_responses",
          "o3-mini": "none",
          "o3-pro": "files_api_responses",
          "o4-mini": "files_api_responses"
        },
        "default_model": "gpt-5.5"
      },
      "xai": {
        "api_endpoint": "https://api.x.ai/v1/chat/completions",
        "api_key_env": "XAI_API_KEY",
        "available_models": [
          "grok-4.20-0309-non-reasoning",
          "grok-4.20-0309-reasoning",
          "grok-4.3",
          "grok-build-0.1"
        ],
        "pdf_strategy": {
          "grok-4.20-0309-non-reasoning": "none",
          "grok-4.20-0309-reasoning": "rasterize_to_images",
          "grok-4.3": "rasterize_to_images",
          "grok-build-0.1": "none"
        },
        "default_model": "grok-4.20-0309-non-reasoning"
      }
    }
  },
  "pdf": {
    "max_pages_before_extraction": 3,
    "extraction_pages": 3
  },
  "ocr": {
    "enable_embedding": false,
    "min_text_per_page": 50,
    "language": "eng",
    "dpi": 300
  },
  "google_drive": {
    "credentials_file": "credentials.json",
    "token_file": "token.json",
    "scopes": [
      "https://www.googleapis.com/auth/drive"
    ]
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(levelname)s - %(message)s",
    "date_format": "%Y-%m-%dT%H:%M:%S.%f%z",
    "file": "scan_namer.log"
  }
}
